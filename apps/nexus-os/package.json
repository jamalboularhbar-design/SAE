  "private": true,
  "type": "module",
  "license": "MIT",
  "description": "Nexus OS — an autonomous AI operating system. Ask once; a team of specialist agents executes across your tools.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch server/index.ts",
